# URL canonique du site, PAR ENVIRONNEMENT (la seule variable qui diffère d'un env
# à l'autre). Alimente site.url (@nuxtjs/seo) et i18n.baseUrl (canonical + alternate
# hreflang absolus, og:image absolu, sitemap). Défaut code si vide:
# https://rempartextermination.ca (la démo).
# Sur Cloudflare, POSÉE PAR WORKER (Settings > Variables and Secrets):
#   prod    -> https://webforge-ancree.patoinestudio.ca
#   staging -> https://webforge-ancree-staging.patoinestudio.ca
#   preview -> https://webforge-ancree-preview.patoinestudio.ca
# En local, laisser vide (défaut) ou poser l'URL de prod pour inspecter le SEO.
NUXT_PUBLIC_SITE_URL=

# Formulaire de contact — Resend.
# Vide = MODE DÉMO: la route /api/contact valide les champs et renvoie un succès
# (l'écran de confirmation s'affiche), mais n'envoie AUCUN courriel. Pose ces
# variables (en local ici, ou par Worker dans Cloudflare Workers > Settings >
# Variables and Secrets) pour activer l'envoi réel.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Anti-bot — Cloudflare Turnstile.
# Site key vide = le widget n'est pas rendu et la vérification serveur est
# ignorée (mode démo). Les deux clés sont requises pour activer la protection;
# une fois la clé secrète posée, la route est fail-closed (refuse sans jeton valide).
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Sanity — project « WebForge - Ancrée Demo » (org Patoine Studio, contrat §17).
# La connexion (projectId, dataset, apiVersion) vit en CONSTANTES DE CODE dans
# nuxt.config.ts (défauts: 5if00rwn / production / 2026-06-01). AUCUNE de ces
# trois variables n'est requise: elles ne changent pas selon l'environnement,
# seulement d'un site à l'autre (un client qui forke change le bloc dans le code).
# Le build exige seulement un ACCÈS RÉSEAU à Sanity (fetch des slugs des routes).
#
# Override optionnel seulement, en connaissance de cause (ids non sensibles, ils
# circulent dans les URL du CDN). Décommenter pour forcer une valeur:
# NUXT_PUBLIC_SANITY_PROJECT_ID=5if00rwn
# NUXT_PUBLIC_SANITY_DATASET=production
# NUXT_PUBLIC_SANITY_API_VERSION=2026-06-01

# Sanity — preview (drafts + visual editing). Les DEUX variables ci-dessous
# sont les interrupteurs du mode preview: le bloc sanity.visualEditing de
# nuxt.config ne s'active que si LES DEUX sont posées. L'une ou l'autre vide =
# preview entièrement désactivé (ni stega, ni routes /preview/*, ni React dans
# le build). Production statique (Cloudflare Workers): les laisser VIDES.
# Même code sur toutes les branches, la divergence passe par l'env seulement.

# Token API rôle Viewer (manage.sanity.io > API > Tokens). Server-only, JAMAIS
# commité, jamais exposé au navigateur (le module le garde côté privé et passe
# par son proxy serveur). Sert à valider le secret de preview et lire les drafts.
SANITY_API_READ_TOKEN=

# URL du Studio (stega encoding du click-to-edit + liens vers le Studio).
# Dev local: le Studio tourne sur 3333 (yarn studio:dev à la racine), le
# Presentation tool charge le front sur localhost:3000.
NUXT_PUBLIC_STUDIO_URL=http://localhost:3333
