# Studio Sanity, démo WebForge Ancrée.
# Les valeurs par défaut (fallback dans sanity.config.ts et sanity.cli.ts)
# couvrent le dev local: ce fichier sert surtout de référence.

# Project « WebForge - Ancrée » (5if00rwn), org Patoine Studio.
SANITY_STUDIO_PROJECT_ID=5if00rwn
SANITY_STUDIO_DATASET=production

# Origine du site pour l'iframe du Presentation tool.
# Dev local: le dev server de l'app sur le port 3000.
# Au branchement Cloudflare: l'URL du déploiement SSR de la branche preview.
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
